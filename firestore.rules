rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow public read access to vehicles, routes, and alerts
    // This allows passengers to track buses without signing in
    match /vehicles/{vehicleId} {
      allow read: if true;
      allow write: if request.auth != null; // Only authenticated users (Drivers/Admins) can update position
    }
    
    match /routes/{routeId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.role == "admin"; // Only admins can modify routes
    }
    
    match /alerts/{alertId} {
      allow read: if true;
      allow create, update: if request.auth != null; // Drivers and Admins can create alerts
      allow delete: if request.auth != null && request.auth.token.role == "admin";
    }

    // Default deny for everything else
    match /{document=**} {
      allow read, write: if request.auth != null && request.auth.token.role == "admin";
    }
  }
}
